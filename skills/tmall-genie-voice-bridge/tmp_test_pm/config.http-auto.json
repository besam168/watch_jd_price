{
  "host": "127.0.0.1",
  "port": 57891,
  "tts": {
    "provider": "mock",
    "voice": "zh-CN-XiaoxiaoNeural",
    "rate": "+0%",
    "output_dir": "./tmp_audio",
    "output_ext": "wav"
  },
  "backend": {
    "type": "local_http_player",
    "options": {}
  },
  "http_player": {
    "player_url": "http://127.0.0.1:57901/play",
    "method": "POST",
    "timeout": 15,
    "headers": {
      "Content-Type": "application/json"
    },
    "body_template": {
      "entity_id": "media_player.tmall_genie",
      "media_content_id": "{{audio_url}}",
      "media_content_type": "music",
      "spoken_text": "{{text}}"
    },
    "audio_base_url": "auto",
    "public_base_url": ""
  }
}
