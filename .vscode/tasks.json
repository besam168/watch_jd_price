        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\skills\\gemini-bridge\\scripts\\run-gemini.ps1",
        "-Prompt",
        "Reply with exactly GEMINI_VSCODE_OK",
        "-Json"
      ],
      "problemMatcher": []
    },
    {
      "label": "Gemini Bridge: Repo Analyze",
      "type": "shell",
